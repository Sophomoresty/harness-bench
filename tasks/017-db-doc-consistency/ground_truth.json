{
  "min_subtasks": 3,
  "expected_subtask_topics": [
    "Parse structured SQL data (including multi‑environment and node tables)",
    "Parse unstructured Markdown data (including parameters and node tables)",
    "Parse YAML environment override configurations",
    "Parse JSON node hardware inventory",
    "Cross‑reference and generate conflict report"
  ],
  "required_files": [
    "audit_report.csv",
    "progress.md"
